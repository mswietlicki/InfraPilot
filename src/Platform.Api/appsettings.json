{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Mode": "Local"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<your-tenant-id>",
    "ClientId": "<your-client-id>",
    "Audience": "<your-audience>"
  },
  "Graph": {
    "TenantId": "<your-tenant-id>",
    "ClientId": "<your-graph-client-id>",
    "ClientSecret": "<your-graph-client-secret>"
  },
  "AzureOpenAI": {
    "Endpoint": "<your-openai-endpoint>",
    "ApiKey": "<your-openai-api-key>",
    "DeploymentName": "gpt-4.1"
  },
  "ConnectionStrings": {
    "Platform": "Host=localhost;Database=platform;Username=postgres;Password=postgres"
  },
  "AzureBlob": {
    "ConnectionString": "<blob-connection-string>",
    "ContainerName": "request-attachments"
  },
  "ServiceBus": {
    "ConnectionString": "<servicebus-connection-string>",
    "ExecutionQueueName": "request-execution"
  },
  "Notifications": {
    "PortalBaseUrl": "https://localhost:5001",
    "Channels": {
      "Email": {
        "Enabled": false,
        "SmtpHost": "localhost",
        "SmtpPort": 25,
        "From": "noreply@platform.local",
        "UseSsl": false
      },
      "Webhook": {
        "Enabled": false,
        "Url": "",
        "Headers": {}
      }
    }
  },
  "AzureDevOps": {
    "Connections": {}
  },
  "Jira": {
    "Connections": {}
  },
  "Deployments": {
    "ApiKeys": [],
    "IngestionRateLimit": {
      "AuthenticatedPermitLimit": 120,
      "AnonymousPermitLimit": 10,
      "WindowSeconds": 60,
      "SegmentsPerWindow": 6
    },
    "Enrichment": {
      "Enabled": false,
      "IntervalSeconds": 30,
      "MaxEventsPerCycle": 10,
      "LookbackHours": 24
    }
  },
  "Catalog": {
    "Path": "../../catalog/examples"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  }
}
