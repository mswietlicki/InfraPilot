{
  "AzureAd": {
    "TenantId": "<your-entra-tenant-id>",
    "ClientId": "<your-app-client-id>",
    "Audience": "api://<your-app-client-id>"
  },
  "Graph": {
    "TenantId": "<your-entra-tenant-id>",
    "ClientId": "<your-graph-app-client-id>",
    "ClientSecret": "<your-graph-client-secret>"
  },
  "AzureOpenAI": {
    "Endpoint": "https://<your-resource>.cognitiveservices.azure.com/",
    "ApiKey": "<your-openai-api-key>"
  },
  "ConnectionStrings": {
    "Platform": "Host=localhost;Database=platform;Username=postgres;Password=postgres"
  },
  "AzureDevOps": {
    "Connections": {
      "my-org": {
        "OrganizationUrl": "https://dev.azure.com/<your-org>",
        "Project": "<your-project>",
        "Pat": "<your-personal-access-token>"
      }
    }
  },
  "Jira": {
    "Connections": {
      "default": {
        "BaseUrl": "https://<your-org>.atlassian.net",
        "Email": "<your-email>",
        "ApiToken": "<your-jira-api-token>"
      }
    }
  },
  "Deployments": {
    "ApiKeys": [
      {
        "Name": "azure-devops-pipeline",
        "Key": "<generate-a-strong-key>",
        "Roles": ["InfraPortal.User"]
      },
      {
        "Name": "github-actions",
        "Key": "<generate-a-strong-key>",
        "Roles": ["InfraPortal.User"]
      }
    ],
    "IngestionRateLimit": {
      "AuthenticatedPermitLimit": 120,
      "AnonymousPermitLimit": 10,
      "WindowSeconds": 60,
      "SegmentsPerWindow": 6
    },
    "Enrichment": {
      "Enabled": true
    }
  },
  "Notifications": {
    "PortalBaseUrl": "https://localhost:5001"
  }
}
